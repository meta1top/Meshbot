#!/bin/sh
set -e

echo "[pre-commit] running biome (incremental via lint-staged)..."
pnpm exec lint-staged

echo "[pre-commit] running 5 static fences..."
pnpm check

echo "[pre-commit] checking skill <-> rule sync..."
pnpm sync:skills -- --check

echo "[pre-commit] checking i18n key alignment (soft)..."
pnpm sync:locales -- --check || echo "[warn] sync:locales reports gaps; run 'pnpm sync:locales -- --write' to fill placeholders"
