{
  "name": "anybot",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web-agent": "pnpm --filter @anybot/web-agent dev",
    "dev:web-main": "pnpm --filter @anybot/web-main dev",
    "dev:server-agent": "pnpm --filter @anybot/server-agent dev",
    "dev:server-main": "pnpm --filter @anybot/server-main dev",
    "dev:desktop": "pnpm --filter @anybot/desktop dev",
    "proxy:deepseek": "pnpm --filter @anybot/cursor-deepseek start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "turbo": "^2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.8.1"
}
