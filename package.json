{
  "name": "meshbot",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:types": "turbo run build --filter=@meshbot/types",
    "build:types-agent": "turbo run build --filter=@meshbot/types-agent",
    "build:common": "turbo run build --filter=@meshbot/common",
    "build:web-agent": "turbo run build --filter=@meshbot/web-agent",
    "build:web-main": "turbo run build --filter=@meshbot/web-main",
    "build:server-agent": "turbo run build --filter=@meshbot/server-agent",
    "build:server-main": "turbo run build --filter=@meshbot/server-main",
    "build:desktop": "turbo run build --filter=@meshbot/desktop",
    "build:cli-agent": "turbo run build --filter=@meshbot/cli-agent",
    "start:server-main": "pnpm --filter @meshbot/server-main start",
    "dev": "turbo run dev",
    "dev:web-agent": "turbo run dev --filter=@meshbot/web-agent...",
    "dev:web-main": "turbo run dev --filter=@meshbot/web-main...",
    "dev:server-agent": "turbo run dev --filter=@meshbot/server-agent...",
    "dev:server-main": "turbo run dev --filter=@meshbot/server-main...",
    "dev:desktop": "turbo run dev --filter=@meshbot/desktop",
    "dev:cli-agent": "turbo run dev --filter=@meshbot/cli-agent...",
    "dev:db:up": "docker compose -f infra/dev/docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f infra/dev/docker-compose.dev.yml down",
    "dev:db:reset": "docker compose -f infra/dev/docker-compose.dev.yml down -v && docker compose -f infra/dev/docker-compose.dev.yml up -d",
    "dev:db:logs": "docker compose -f infra/dev/docker-compose.dev.yml logs -f postgres",
    "pkg:app": "turbo run build --filter=@meshbot/desktop && pnpm --filter @meshbot/desktop run dist",
    "rebuild:native": "tsx scripts/rebuild-native.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:format": "biome check --write .",
    "check:tx": "tsx scripts/check-transactional.ts",
    "check:naming": "tsx scripts/check-method-naming.ts",
    "check:lock-tx": "tsx scripts/check-lock-tx.ts",
    "check:repo": "tsx scripts/check-repo-access.ts",
    "check:scope": "tsx scripts/check-scope-access.ts",
    "check:dead": "tsx scripts/check-dead-exports.ts",
    "check:error-code": "tsx scripts/check-error-code.ts",
    "check:pk": "tsx scripts/check-pk.ts",
    "check:dev-script": "tsx scripts/check-dev-script.ts",
    "check": "pnpm check:tx && pnpm check:naming && pnpm check:lock-tx && pnpm check:repo && pnpm check:scope && pnpm check:dead && pnpm check:error-code && pnpm check:pk && pnpm check:dev-script",
    "check:strict": "pnpm check:tx -- --strict && pnpm check:naming -- --strict && pnpm check:lock-tx -- --strict && pnpm check:repo -- --strict && pnpm check:scope -- --strict && pnpm check:dead -- --strict && pnpm check:error-code -- --strict && pnpm check:pk -- --strict && pnpm check:dev-script -- --strict",
    "check:parallel": "pnpm run \"/^check:(tx|naming|lock-tx|repo|scope|dead|error-code|pk|dev-script)$/\"",
    "sync:locales": "tsx scripts/sync-locales.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "migration:agent": "pnpm --filter @meshbot/server-agent migration",
    "migration:archive:agent": "pnpm --filter @meshbot/server-agent migration:archive",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.18",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "lru-cache": "^11.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
