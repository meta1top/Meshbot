{
  "name": "anybot",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:types": "pnpm --filter @anybot/types build",
    "build:types-agent": "pnpm --filter @anybot/types-agent build",
    "build:shared": "pnpm --filter @anybot/shared build",
    "build:common": "pnpm --filter @anybot/common build",
    "build:web-agent": "pnpm --filter @anybot/web-agent build",
    "build:server-agent": "pnpm --filter @anybot/server-agent build",
    "build:desktop": "pnpm --filter @anybot/desktop build",
    "build:cli-agent": "turbo run build --filter=@anybot/cli-agent",
    "dev": "turbo run dev",
    "dev:web-agent": "pnpm --filter @anybot/web-agent dev",
    "dev:web-main": "pnpm --filter @anybot/web-main dev",
    "dev:server-agent": "pnpm --filter @anybot/server-agent dev",
    "dev:server-main": "pnpm --filter @anybot/server-main dev",
    "dev:desktop": "pnpm --filter @anybot/desktop dev",
    "dev:cli-agent": "turbo run dev --filter=@anybot/cli-agent",
    "pkg:prepare-server-agent": "node scripts/prepare-server-agent.mjs",
    "pkg:rebuild-server-agent-native": "pnpm --filter @anybot/desktop exec electron-rebuild -v 41.5.0 -m ../../apps/server-agent/.bundle/pack/srv -o better-sqlite3,bcrypt --build-from-source",
    "pkg:app": "pnpm run build:types && pnpm run build:common && pnpm run build:types-agent && pnpm run build:shared && pnpm run build:web-agent && pnpm run build:server-agent && pnpm run pkg:prepare-server-agent && pnpm run pkg:rebuild-server-agent-native && pnpm run build:desktop && pnpm --filter @anybot/desktop run dist",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "turbo": "^2.9.12",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.8.1"
}
