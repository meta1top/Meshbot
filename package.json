{
  "name": "meshbot",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:types": "pnpm --filter @meshbot/types build",
    "build:types-agent": "pnpm --filter @meshbot/types-agent build",
    "build:common": "pnpm --filter @meshbot/common build",
    "build:web-agent": "pnpm --filter @meshbot/web-agent build",
    "build:server-agent": "pnpm --filter @meshbot/server-agent build",
    "build:server-main": "pnpm --filter @meshbot/server-main build",
    "start:server-main": "pnpm --filter @meshbot/server-main start",
    "build:desktop": "pnpm --filter @meshbot/desktop build",
    "build:cli-agent": "turbo run build --filter=@meshbot/cli-agent",
    "dev": "turbo run dev",
    "dev:web-agent": "pnpm --filter @meshbot/web-agent dev",
    "dev:web-main": "pnpm --filter @meshbot/web-main dev",
    "dev:server-agent": "pnpm --filter @meshbot/server-agent dev",
    "dev:server-main": "pnpm --filter @meshbot/server-main dev",
    "dev:desktop": "pnpm --filter @meshbot/desktop dev",
    "dev:cli-agent": "turbo run dev --filter=@meshbot/cli-agent",
    "dev:db:up": "docker compose -f infra/dev/docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f infra/dev/docker-compose.dev.yml down",
    "dev:db:reset": "docker compose -f infra/dev/docker-compose.dev.yml down -v && docker compose -f infra/dev/docker-compose.dev.yml up -d",
    "dev:db:logs": "docker compose -f infra/dev/docker-compose.dev.yml logs -f postgres",
    "pkg:app": "pnpm run build:types && pnpm run build:common && pnpm run build:types-agent && pnpm run build:web-agent && pnpm run build:desktop && pnpm --filter @meshbot/desktop run dist",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:format": "biome check --write .",
    "check:tx": "tsx scripts/check-transactional.ts",
    "check:naming": "tsx scripts/check-method-naming.ts",
    "check:lock-tx": "tsx scripts/check-lock-tx.ts",
    "check:repo": "tsx scripts/check-repo-access.ts",
    "check:dead": "tsx scripts/check-dead-exports.ts",
    "check:error-code": "tsx scripts/check-error-code.ts",
    "check": "pnpm check:tx && pnpm check:naming && pnpm check:lock-tx && pnpm check:repo && pnpm check:dead && pnpm check:error-code",
    "check:strict": "pnpm check:tx -- --strict && pnpm check:naming -- --strict && pnpm check:lock-tx -- --strict && pnpm check:repo -- --strict && pnpm check:dead -- --strict && pnpm check:error-code -- --strict",
    "check:parallel": "pnpm run \"/^check:(tx|naming|lock-tx|repo|dead|error-code)$/\"",
    "sync:locales": "tsx scripts/sync-locales.ts",
    "sync:skills": "tsx scripts/sync-skills.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "migration:generate:main": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:generate -d apps/server-main/src/data-source.cli.ts",
    "migration:run:main": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:run -d apps/server-main/src/data-source.cli.ts",
    "migration:revert:main": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:revert -d apps/server-main/src/data-source.cli.ts",
    "migration:show:main": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:show -d apps/server-main/src/data-source.cli.ts",
    "migration:generate:agent": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:generate -d apps/server-agent/src/data-source.cli.ts",
    "migration:run:agent": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:run -d apps/server-agent/src/data-source.cli.ts",
    "migration:revert:agent": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:revert -d apps/server-agent/src/data-source.cli.ts",
    "migration:show:agent": "TS_NODE_COMPILER_OPTIONS='{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true,\"target\":\"ES2022\",\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"esModuleInterop\":true}' typeorm-ts-node-commonjs migration:show -d apps/server-agent/src/data-source.cli.ts",
    "migration:archive:main": "tsx scripts/archive-migrations.ts apps/server-main",
    "migration:archive:agent": "tsx scripts/archive-migrations.ts apps/server-agent",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "lru-cache": "^11.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^22"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
