# meshbot server-main 生产环境变量样例。
# 1. cp .env.prod.example .env.prod
# 2. 修改下方 <change-me> 占位为真实 secret
# 3. docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# .env.prod 应 gitignore（仓库根 .gitignore 已覆盖 .env.*）

# ---- 数据库 ----
POSTGRES_USER=meshbot
POSTGRES_PASSWORD=<change-me-strong-password>
POSTGRES_DB=meshbot_main

# ---- JWT ----
# 用 `openssl rand -base64 48` 生成 32 字节以上
JWT_SECRET=<change-me-base64-32-bytes>
JWT_EXPIRES=7d

# ---- 暴露端口 ----
SERVER_MAIN_PORT=3200
