{
  "name": "@meshbot/web-common",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./shell": {
      "types": "./src/shell/index.ts",
      "default": "./src/shell/index.ts"
    },
    "./im": {
      "types": "./src/im/index.ts",
      "default": "./src/im/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@meshbot/design": "workspace:*",
    "@meshbot/types": "workspace:*",
    "@meshbot/types-agent": "workspace:*",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.16.0",
    "best-effort-json-parser": "^1.4.1",
    "lucide-react": "^0.468",
    "tiptap-markdown": "^0.9.0",
    "zod": "^3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19"
  }
}
