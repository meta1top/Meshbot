{
  "name": "@meshbot/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && node scripts/copy-web-agent.js",
    "dev": "tsc --project tsconfig.json && electron .",
    "start": "electron dist/main.js",
    "clean": "rm -rf dist release release-stage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "stage": "node scripts/stage.js",
    "pack": "pnpm run stage && electron-builder --projectDir release-stage --dir",
    "dist": "pnpm run stage && electron-builder --projectDir release-stage"
  },
  "files": [
    "dist",
    "scripts",
    "electron-builder.yml"
  ],
  "dependencies": {
    "@meshbot/server-agent": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "bcrypt": "^6.0.0",
    "electron-updater": "^6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^24",
    "electron": "^41",
    "electron-builder": "26.8.1",
    "vitest": "^4.1.5"
  }
}
