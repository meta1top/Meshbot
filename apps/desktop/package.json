{
  "name": "@anybot/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json && electron .",
    "start": "electron dist/main.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anybot/common": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "electron": "^41",
    "electron-builder": "^25",
    "vitest": "^4.1.5"
  }
}
