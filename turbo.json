{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**", "tsconfig.tsbuildinfo"]
    },
    "@meshbot/server-agent#build": {
      "dependsOn": ["^build", "@meshbot/web-agent#build"],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"]
    },
    "@meshbot/desktop#build": {
      "dependsOn": [
        "^build",
        "@meshbot/web-agent#build",
        "@meshbot/server-agent#build"
      ],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
